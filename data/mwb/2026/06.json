                },
                {
                    "tipo": "subtema",
                    "texto": "🌾 EMPENHE-SE NO MINISTÉRIO"
                },
                {
                    "tipo": "subtema",
                    "texto": "4. Iniciar conversas"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "TESTEMUNHO INFORMAL. (lmd lição 5 ponto 5)",
                    "numero_ref": "8"
                },
                {
                    "tipo": "subtema",
                    "texto": "5. Cultivar o interesse"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "DE CASA EM CASA. Fale sobre uma das verdades do apêndice A da brochura Ame as Pessoas. (lmd lição 9 ponto 3)",
                    "numero_ref": "9"
                },
                {
                    "tipo": "subtema",
                    "texto": "6. Fazer discípulos"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "lff lição 19 ponto 6 (th lição 19)",
                    "numero_ref": "10"
