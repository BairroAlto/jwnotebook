{
    "artigos": [
        {
            "referencia": "mwb26 março p. 2 março",
            "titulo": "2 A 8 DE MARÇO",
            "conteudo": [
                {
                    "tipo": "subtema",
                    "texto": "Cântico 8 e oração | Comentários iniciais"
                },
                {
                    "tipo": "subtema",
                    "texto": "ISAÍAS 41-42"
                },
                {
                    "tipo": "subtema",
                    "texto": "💎 TESOUROS DA PALAVRA DE DEUS"
                },
                {
                    "tipo": "subtema",
                    "texto": "1. “Não tenhas medo”"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Jeová levantaria “alguém do nascente” que faria as pessoas tremer. (Isa. 41:2, 5; ip-2-T 20 § 10)",
                    "numero_ref": "1"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Os adoradores de Jeová não precisariam de ter medo. (Isa. 41:10; ijwbv artigo 5 §§ 4-7)",
                    "numero_ref": "2"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Jeová iria ajudá-los. (Isa. 41:13)",
                    "numero_ref": "3"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "PARA MEDITAR: Como é que a profecia no capítulo 41 de Isaías ajuda os cristãos atualmente? – w16.07-T 18 §§ 4-5.",
                    "numero_ref": "4"
                },
                {
                    "tipo": "subtema",
                    "texto": "2. Pérolas espirituais"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Isa. 41:8— Como é que Jeová mostrou que Abraão era amigo dele? (w01-T 1/10 20 § 3)",
                    "numero_ref": "5"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Que pérolas espirituais encontrou na leitura da Bíblia desta semana?",
                    "numero_ref": "6"
                },
                {
                    "tipo": "subtema",
                    "texto": "3. Leitura da Bíblia"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Isa. 42:1-13 (th lição 11)",
                    "numero_ref": "7"
                },
                {
                    "tipo": "subtema",
                    "texto": "🌾 EMPENHE-SE NO MINISTÉRIO"
                },
                {
                    "tipo": "subtema",
                    "texto": "4. Iniciar conversas"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "DE CASA EM CASA. O morador aceita o convite para o Memorial e mostra interesse. (lmd lição 6 ponto 4)",
                    "numero_ref": "8"
                },
                {
                    "tipo": "subtema",
                    "texto": "5. Iniciar conversas"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "TESTEMUNHO INFORMAL. Convide um familiar para o Memorial e use o site jw.org para encontrar um local perto dele. (lmd lição 3 ponto 5)",
                    "numero_ref": "9"
                },
                {
                    "tipo": "subtema",
                    "texto": "6. Explicar as suas crenças"
                },
                {
                    "tipo": "subtema",
                    "texto": "Discurso. ijwbq artigo 60 — Tema: Como superar o medo da morte? (th lição 1)"
                },
                {
                    "tipo": "subtema",
                    "texto": "🐑 VIVER COMO CRISTÃOS"
                },
                {
                    "tipo": "subtema",
                    "texto": "Cântico 19"
                },
                {
                    "tipo": "subtema",
                    "texto": "7. A campanha do Memorial começa no sábado, 7 de março"
                },
                {
                    "tipo": "subtema",
                    "texto": "Discurso feito pelo superintendente do serviço. Explique quais são os planos da congregação para a campanha, para o discurso especial e para o Memorial. Incentive todos a participarem mais na pregação durante os meses de março e abril. Os publicadores podem servir como pioneiros auxiliares com um requisito de 15 horas."
                },
                {
                    "tipo": "subtema",
                    "texto": "8. Realizações da Organização de março"
                },
                {
                    "tipo": "subtema",
                    "texto": "Discurso com participação da assistência."
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Mostre o VÍDEO. Depois, faça as perguntas que aparecem no vídeo.",
                    "numero_ref": "10"
                },
                {
                    "tipo": "subtema",
                    "texto": "9. Estudo bíblico de congregação"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "lfb histórias 66 e 67",
                    "numero_ref": "11"
                },
                {
                    "tipo": "rodape",
                    "texto": "Comentários finais | Cântico 110 e oração"
                }
            ]
        },
        {
            "referencia": "mwb26 março p. 3 março",
            "titulo": "9 A 15 DE MARÇO",
            "conteudo": [
                {
                    "tipo": "subtema",
                    "texto": "Cântico 63 e oração | Comentários iniciais"
                },
                {
                    "tipo": "subtema",
                    "texto": "ISAÍAS 43-44"
                },
                {
                    "tipo": "subtema",
                    "texto": "💎 TESOUROS DA PALAVRA DE DEUS"
                },
                {
                    "tipo": "subtema",
                    "texto": "1. Uma profecia escrita com dois séculos de antecedência"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Os rios de Babilónia iriam ‘secar’. (Isa. 44:27; gm-T 123-124 §§ 16-17)",
                    "numero_ref": "1"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Um conquistador chamado Ciro iria atuar como “pastor” de Deus. (Isa. 44:28a; it-T “Ciro” § 6)",
                    "numero_ref": "2"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Ciro iria enviar o povo de Jeová de volta a Jerusalém para reconstruirem a cidade e o templo. (Esd. 1:1-3; Isa. 44:28b; it-T “Ciro” § 16)",
                    "numero_ref": "3"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "PARA PESQUISAR: Como é que Ciro cumpriu as palavras registadas em Isaías 45:1-4?",
                    "numero_ref": "4"
                },
                {
                    "tipo": "subtema",
                    "texto": "2. Pérolas espirituais"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Isa. 44:28 — Como é que sabemos que Jeová não interferiu com a liberdade de escolha de Ciro? (w24.02 30 § 8)",
                    "numero_ref": "5"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Que pérolas espirituais encontrou na leitura da Bíblia desta semana?",
                    "numero_ref": "6"
                },
                {
                    "tipo": "subtema",
                    "texto": "3. Leitura da Bíblia"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Isa. 44:9-20 (th lição 10)",
                    "numero_ref": "7"
                },
                {
                    "tipo": "subtema",
                    "texto": "🌾 EMPENHE-SE NO MINISTÉRIO"
                },
                {
                    "tipo": "subtema",
                    "texto": "4. Iniciar conversas"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "DE CASA EM CASA. Ofereça um convite para o Memorial. (lmd lição 4 ponto 3)",
                    "numero_ref": "8"
                },
                {
                    "tipo": "subtema",
                    "texto": "5. Iniciar conversas"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "TESTEMUNHO INFORMAL. Convide um conhecido para o Memorial. (lmd lição 3 ponto 4)",
                    "numero_ref": "9"
                },
                {
                    "tipo": "subtema",
                    "texto": "6. Iniciar conversas"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "TESTEMUNHO INFORMAL. Peça ao seu patrão que lhe dê tempo livre para assistir ao Memorial. (lmd lição 6 ponto 3)",
                    "numero_ref": "10"
                },
                {
                    "tipo": "subtema",
                    "texto": "7. Cultivar o interesse"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "DE CASA EM CASA. Ofereça um estudo bíblico a alguém que aceitou um convite para o Memorial na visita anterior. (lmd lição 7 ponto 4)",
                    "numero_ref": "11"
                },
                {
                    "tipo": "subtema",
                    "texto": "🐑 VIVER COMO CRISTÃOS"
                },
                {
                    "tipo": "subtema",
                    "texto": "Cântico 69"
                },
                {
                    "tipo": "subtema",
                    "texto": "8. Necessidades locais"
                },
                {
                    "tipo": "subtema",
                    "texto": "9. Estudo bíblico de congregação"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "lfb introdução da secção 11 e histórias 68 e 69",
                    "numero_ref": "12"
                },
                {
                    "tipo": "rodape",
                    "texto": "Comentários finais | Cântico 137 e oração"
                }
            ]
        },
        {
            "referencia": "mwb26 março março pp. 4-5",
            "titulo": "16 A 22 DE MARÇO",
            "conteudo": [
                {
                    "tipo": "subtema",
                    "texto": "Cântico 2 e oração | Comentários iniciais"
                },
                {
                    "tipo": "subtema",
                    "texto": "ISAÍAS 45-47"
                },
                {
                    "tipo": "subtema",
                    "texto": "💎 TESOUROS DA PALAVRA DE DEUS"
                },
                {
                    "tipo": "subtema",
                    "texto": "1. “Eu sou Deus, e não há ninguém igual a mim”"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Não existe ninguém como Jeová. (Isa. 46:9; w20.06 5 § 14)",
                    "numero_ref": "1"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Nada pode impedir Jeová de cumprir a sua vontade. (Isa. 46:10, 11; cl-T 42 § 14; it-T “Exilados Retornam de Babilônia” § 1)",
                    "numero_ref": "2"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Aqueles que confiam em deuses falsos ficam desiludidos. (Isa. 46:6, 7; w99-T 15/5 14 §§ 18-19)",
                    "numero_ref": "3"
                },
                {
                    "tipo": "subtema",
                    "texto": "2. Pérolas espirituais"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Isa. 46:10 — Será que Jeová sabia “desde o princípio” que Adão e Eva iam pecar? (w11-T 1/1 14 §§ 2-3)",
                    "numero_ref": "4"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Que pérolas espirituais encontrou na leitura da Bíblia desta semana?",
                    "numero_ref": "5"
                },
                {
                    "tipo": "subtema",
                    "texto": "3. Leitura da Bíblia"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Isa. 45:1-11 (th lição 5)",
                    "numero_ref": "6"
                },
                {
                    "tipo": "subtema",
                    "texto": "🌾 EMPENHE-SE NO MINISTÉRIO"
                },
                {
                    "tipo": "subtema",
                    "texto": "4. Iniciar conversas"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "TESTEMUNHO PÚBLICO. Explique o que é o Memorial a uma pessoa que não é cristã. (lmd lição 5 ponto 3)",
                    "numero_ref": "7"
                },
                {
                    "tipo": "subtema",
                    "texto": "5. Cultivar o interesse"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "DE CASA EM CASA. Ofereça um estudo bíblico a alguém que aceitou um convite para o Memorial na visita anterior. (lmd lição 9 ponto 5)",
                    "numero_ref": "8"
                },
                {
                    "tipo": "subtema",
                    "texto": "6. Fazer discípulos"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "lff lição 19, introdução e pontos 1-3 (lmd lição 11 ponto 3)",
                    "numero_ref": "9"
                },
                {
                    "tipo": "subtema",
                    "texto": "🐑 VIVER COMO CRISTÃOS"
                },
                {
                    "tipo": "subtema",
                    "texto": "Cântico 38"
                },
                {
                    "tipo": "subtema",
                    "texto": "7. Jeová pode sempre ajudar-nos"
                },
                {
                    "tipo": "subtema",
                    "texto": "Discurso com participação da assistência."
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Quando passamos por problemas, Jeová é o único em quem nós podemos confiar totalmente. — Heb. 13:5, 6.",
                    "numero_ref": "10"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Leia o Salmo 55:22. Depois, analise com a assistência as seguintes situações.",
                    "numero_ref": "11"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Para cada situação, escreva uma forma de mostrar que confia em Jeová e como é que ele nos pode ajudar.",
                    "numero_ref": "12"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Perdemos o emprego ou temos dificuldade em sustentar a nossa família",
                    "numero_ref": "13"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "As autoridades proíbem as nossas atividades teocráticas",
                    "numero_ref": "14"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Enfrentamos problemas de saúde graves",
                    "numero_ref": "15"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Passamos por uma tragédia, como um desastre natural ou a morte de alguém que amamos",
                    "numero_ref": "16"
                },
                {
                    "tipo": "subtema",
                    "texto": "8. Departamento Mundial de Projeto e Construção – Atualização de 2026"
                },
                {
                    "tipo": "subtema",
                    "texto": "Discurso."
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Mostre o VÍDEO.",
                    "numero_ref": "17"
                },
                {
                    "tipo": "subtema",
                    "texto": "9. Estudo bíblico de congregação"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "lfb histórias 70 e 71",
                    "numero_ref": "18"
                },
                {
                    "tipo": "rodape",
                    "texto": "Comentários finais | Cântico 148 e oração"
                }
            ]
        },
        {
            "referencia": "mwb26 março março pp. 6-7",
            "titulo": "23 A 29 DE MARÇO",
            "conteudo": [
                {
                    "tipo": "subtema",
                    "texto": "Cântico 89 e oração | Comentários iniciais"
                },
                {
                    "tipo": "subtema",
                    "texto": "ISAÍAS 48-49"
                },
                {
                    "tipo": "subtema",
                    "texto": "💎 TESOUROS DA PALAVRA DE DEUS"
                },
                {
                    "tipo": "subtema",
                    "texto": "1. Prestar atenção ao que Jeová nos ensina beneficia-nos"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Jeová ensina o seu povo. (Isa. 48:17; it-T “Instrutor, Ensino” § 2)",
                    "numero_ref": "1"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Prestar atenção a Jeová é uma escolha que temos de fazer. (Isa. 48:18a; ijwbq artigo 44 §§ 2-3)",
                    "numero_ref": "2"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Assim, a nossa paz vai ser “como um rio” e a nossa justiça “como as ondas do mar”. (Isa. 48:18b; lv 199 § 8)",
                    "numero_ref": "3"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "SIGNIFICADO: A palavra hebraica traduzida como “paz” pode transmitir a ideia de saúde, de segurança, de boas condições, de bem-estar, de amizade e de inteireza ou totalidade.",
                    "numero_ref": "4"
                },
                {
                    "tipo": "subtema",
                    "texto": "2. Pérolas espirituais"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Isa. 49:8 — Esta profecia tem três cumprimentos. Quais são? (it-T “Tempo Aceitável” §§ 1-3)",
                    "numero_ref": "5"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Que pérolas espirituais encontrou na leitura da Bíblia desta semana?",
                    "numero_ref": "6"
                },
                {
                    "tipo": "subtema",
                    "texto": "3. Leitura da Bíblia"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Isa. 48:9-20 (th lição 11)",
                    "numero_ref": "7"
                },
                {
                    "tipo": "subtema",
                    "texto": "🌾 EMPENHE-SE NO MINISTÉRIO"
                },
                {
                    "tipo": "subtema",
                    "texto": "4. Iniciar conversas"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "TESTEMUNHO INFORMAL. Convide um familiar que está inativo para o discurso especial e para o Memorial. (lmd lição 5 ponto 3)",
                    "numero_ref": "8"
                },
                {
                    "tipo": "subtema",
                    "texto": "5. Cultivar o interesse"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "TESTEMUNHO INFORMAL. A pessoa está interessada em ir ao Memorial. Explique o que ela pode esperar do evento e responda às perguntas dela. (lmd lição 9 ponto 3)",
                    "numero_ref": "9"
                },
                {
                    "tipo": "subtema",
                    "texto": "6. Cultivar o interesse"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "TESTEMUNHO INFORMAL. No fim do Memorial, responda às perguntas de um convidado que mostrou interesse. (lmd lição 8 ponto 3)",
                    "numero_ref": "10"
                },
                {
                    "tipo": "subtema",
                    "texto": "🐑 VIVER COMO CRISTÃOS"
                },
                {
                    "tipo": "subtema",
                    "texto": "Cântico 107"
                },
                {
                    "tipo": "subtema",
                    "texto": "7. Beneficie-se do dia mais importante do ano"
                },
                {
                    "tipo": "subtema",
                    "texto": "Discurso com participação da assistência."
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Ao assistirmos ao Memorial todos os anos, mostramos que obedecemos ao mandamento de Jesus e que somos gratos pelo presente do resgate que Jeová nos deu. (Luc. 22:19) No entanto, também é uma ocasião que nos lembra do quanto Jeová e Jesus nos amam. (Gál. 2:20; 1 João 4:9, 10) Como é que podemos preparar o nosso coração para o Memorial e mostrar gratidão a Jeová pelo resgate? Como é que podemos ajudar aqueles que têm interesse a fazer o mesmo?",
                    "numero_ref": "11"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Leia e medite nos versículos da leitura diária da Bíblia para o Memorial.",
                    "numero_ref": "12"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Medite no presente do resgate e em como pode mostrar gratidão na sua vida.",
                    "numero_ref": "13"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Dê o seu melhor na campanha por convidar conhecidos, familiares e pessoas do território para o discurso especial e para o Memorial.",
                    "numero_ref": "14"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Receba de forma amorosa os convidados para o Memorial. Para além de dar atenção àqueles que convidou, também pode estar pronto a ajudar outros que receberam um convite durante a campanha. Até os pode convidar a sentarem-se ao seu lado.",
                    "numero_ref": "15"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Esteja disposto a tirar tempo para responder às perguntas dos convidados.",
                    "numero_ref": "16"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Esteja atento para dar as boas-vindas a quem está inativo. Os anciãos, em particular, vão estar muito atentos para darem as boas-vindas àqueles que já foram Testemunhas de Jeová.",
                    "numero_ref": "17"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "Mostre o VÍDEO Jesus ‘Veio Buscar e Salvar a Que Estava Perdida’. Depois, pergunte:",
                    "numero_ref": "18"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "O que é que aprendeu sobre a importância de recebermos os inativos de forma amorosa no Memorial?",
                    "numero_ref": "19"
                },
                {
                    "tipo": "subtema",
                    "texto": "8. Estudo bíblico de congregação"
                },
                {
                    "tipo": "paragrafo",
                    "texto": "lfb histórias 72 e 73",
                    "numero_ref": "20"
                },
                {
                    "tipo": "rodape",
                    "texto": "Comentários finais | Cântico 134 e oração"
                }
            ]
        }
    ]
}